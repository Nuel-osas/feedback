NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_TIDEFORM_PACKAGE_ID=0x0

# Walrus testnet endpoints (defaults — override per network)
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# TODO_SEAL: comma-separated key server object IDs.
# Leaving this blank enables placeholder mode (private fields are NOT really encrypted).
NEXT_PUBLIC_SEAL_KEY_SERVERS=
NEXT_PUBLIC_SEAL_THRESHOLD=2
