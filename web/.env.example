NEXT_PUBLIC_SUI_NETWORK=mainnet
# Latest package (used for moveCalls — has every module incl. acl).
NEXT_PUBLIC_TIDEFORM_PACKAGE_ID=0x0
# Origin package — used for queryEvents. Leave blank to fall back to PACKAGE_ID.
NEXT_PUBLIC_TIDEFORM_ORIGINAL_PACKAGE_ID=

# Walrus mainnet (via Studio Mirai — proven in production)
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.mainnet.walrus.mirai.cloud
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.mainnet.walrus.mirai.cloud

# Seal mainnet — H2O Nodes Open key server (free, public).
# Threshold=1 since only one open mainnet server is publicly available.
# For higher security, contact additional providers (Ruby Nodes, Overclock, Enoki, …).
NEXT_PUBLIC_SEAL_KEY_SERVERS=0x4a65b4ff7ba8f4b538895ee35959f982a95f0db7e2a202ec989d261ea927286a
NEXT_PUBLIC_SEAL_THRESHOLD=1
